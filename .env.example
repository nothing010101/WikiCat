# ─── RPC ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_CHAIN_ID=8453

# ─── WalletConnect ───────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ─── Relayer / Deployer ──────────────────────────────────────────────────
# WARNING: Never commit this to git. Used only for backend relayer & deploy.
PRIVATE_KEY=your_deployer_private_key_here

# ─── Contract Addresses (fill after deploy) ──────────────────────────────
NEXT_PUBLIC_WIKI_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FOUNDER_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_MINT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Treasury ────────────────────────────────────────────────────────────
TREASURY_ADDRESS=your_treasury_wallet_address

# ─── Founder ─────────────────────────────────────────────────────────────
FOUNDER_ADDRESS=your_founder_wallet_address

# ─── Block Explorer (for verify) ─────────────────────────────────────────
BASESCAN_API_KEY=your_basescan_api_key
